FLASK_SECRET=replace-with-a-long-random-secret
FLASK_DEBUG=false
PORT=5000

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Platform Admin
ADMIN_UNIQUE_ID=admin001
ADMIN_REGISTRATION_CODE=ADMIN2025
FALLBACK_ADMIN_USERNAME=admin001

# Use either the DB_* variables below or Railway-provided MySQL variables.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=evoting_db

# Optional full MySQL connection URL.
# Example: mysql://user:password@host:3306/database
DATABASE_URL=

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@example.com

UPLOAD_FOLDER=templates/static/uploads
