FLASK_SECRET=replace-with-a-long-random-secret
FLASK_DEBUG=false
PORT=5000

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Platform Admin
ADMIN_UNIQUE_ID=platform_admin
ADMIN_REGISTRATION_CODE=ADMIN_ACCESS_CODE
FALLBACK_ADMIN_USERNAME=platform_admin

# Use either the DB_* variables below or Railway-provided MySQL variables.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=evoting_db

# Optional full MySQL connection URL.
# Example: mysql://user:password@host:3306/database
DATABASE_URL=

RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@your-verified-domain.com
RESEND_FROM_NAME=E-Voting Platform

UPLOAD_FOLDER=templates/static/uploads
